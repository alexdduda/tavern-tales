# ── Local AI model (Ollama) ──────────────────────────────────
# The game's Dungeon Master runs on a LOCAL model — no API key, no cost.
# Install Ollama (https://ollama.com) and pull the model:  ollama pull gemma4
VITE_OLLAMA_MODEL=gemma4
# Base URL the browser uses. Default "/ollama" is proxied to localhost:11434
# by vite.config.js (avoids CORS). Override only for a remote Ollama host.
VITE_OLLAMA_URL=/ollama
# Where the Vite dev proxy forwards "/ollama" (optional override).
OLLAMA_HOST=http://localhost:11434

# ── Supabase (optional — cross-device multiplayer) ────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
